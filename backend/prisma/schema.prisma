generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /** Pooled/serverless URL in production (e.g. Neon pooler). */
  url       = env("DATABASE_URL")
  /** Direct (non-pooler) URL for migrations — required by Prisma when set; use same as `DATABASE_URL` for local Postgres. */
  directUrl = env("DIRECT_URL")
}

/** Back-office staff: one bootstrap superuser (CLI), additional admins created only by superuser. */
model StaffUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         StaffRole
  createdAt    DateTime  @default(now())
  createdById  String?
  createdBy    StaffUser?  @relation("StaffCreatedBy", fields: [createdById], references: [id])
  createdStaff StaffUser[] @relation("StaffCreatedBy")
}

enum StaffRole {
  SUPERUSER
  ADMIN
}

model Participant {
  id            String    @id @default(uuid())
  /** Firebase Authentication uid — set on first sync after sign-up */
  firebaseUid   String?   @unique
  fullName      String
  email         String    @unique
  phone         String
  dob           String
  gender        String
  createdAt     DateTime  @default(now())
  /** Set when treasury confirms share capital + membership fees received */
  initialFeesPaidAt   DateTime?
  /** Set when the Board records approval in admin */
  boardApprovedAt     DateTime?
  /** Member finished post-approval full profile + optional sheet upload */
  fullProfileCompletedAt DateTime?
  /** Extra structured fields after board approval (JSON for flexibility) */
  fullProfileJson     String?   @db.Text
  /** Full membership form object (same shape as client `profileJson`) for reporting and admin detail */
  memberProfileSnapshot Json?
  /** Denormalized from full profile for search/list (present address formatted) */
  mailingAddress      String?   @db.Text
  civilStatus           String?
  /** Normalized digits (typically 9). Legacy roster reclaim; do not confuse with `memberIdNo` (B2C public ID). */
  tinNo                 String?
  memberIdNo            String?
  /**
   * Optional member-chosen handle (lowercase). Unique when set; authenticated changes via PATCH /pmes/member/callsign.
   * Alternate public label when set; otherwise see lastNameKey + lastNameSeq (e.g. cruz-2).
   */
  callsign              String?   @unique
  /** Normalized slug from legal last name for default alternate id (e.g. delacruz). */
  lastNameKey           String?
  /** Sequence within lastNameKey for default alternate (brothers share surname → cruz-1, cruz-2). */
  lastNameSeq           Int?
  /** Preloaded roster row (admin import): member reclaims Firebase account + completes digital profile */
  legacyPioneerImport   Boolean   @default(false)
  /**
   * Optimistic concurrency for the membership profile form. Incremented on profile-visible writes (callsign,
   * login-email merge, superuser member ID patch, successful full-profile submit). Not bumped when assigning a
   * provisional public ID during lifecycle loads (`ensureMemberPublicId`), so members are not forced to refresh
   * just because the server filled `memberIdNo`.
   */
  memberProfileConcurrencyStamp Int @default(0)
  /** Full legacy sheet row (B2C registry columns + extras) for audit and reclaim support */
  registryImportSnapshot Json?
  /** Member who referred this account (PIONEER-xxxxxxxx link); set once at first Firebase sync when valid. */
  referredByParticipantId String?
  referredBy                Participant?  @relation("ReferralAttribution", fields: [referredByParticipantId], references: [id], onDelete: SetNull)
  referralReferees          Participant[] @relation("ReferralAttribution")
  /** Set when this member completes full membership (referrer earns Pioneer Points once). */
  referralJoinCreditedAt    DateTime?
  pmesRecords   PmesRecord[]
  loiSubmission LoiSubmission?

  @@index([referredByParticipantId])
}

/** Atomic per-surname sequence for default alternate ids (lastname-1, lastname-2, …). */
model LastNameCounter {
  lastNameKey String @id
  nextSeq     Int    @default(0)
}

model PmesRecord {
  id            String      @id @default(uuid())
  score         Int
  passed        Boolean
  timestamp     DateTime    @default(now())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])
}

model LoiSubmission {
  id             String      @id @default(uuid())
  address        String
  occupation     String
  employer       String
  initialCapital Float
  submittedAt    DateTime    @default(now())
  participantId  String      @unique
  participant    Participant @relation(fields: [participantId], references: [id])
}
