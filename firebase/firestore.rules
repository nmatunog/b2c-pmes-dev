rules_version = '2';

/**
 * PMES data lives under: artifacts/{appId}/public/data/{collection}/{docId}
 * Deploy: `firebase deploy --only firestore:rules` (requires Firebase CLI & project).
 *
 * Admin listing all records in the Firebase client requires `request.auth.token.admin == true`
 * (set via Firebase Admin SDK). Otherwise use the Nest API (`VITE_API_BASE_URL`) for admin.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    /** Per-user PMES session (resume, form draft). Document id must equal auth uid. */
    match /artifacts/{appId}/public/data/pmes_progress/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.userId == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /artifacts/{appId}/public/data/{collection}/{docId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || request.auth.token.admin == true
      );

      allow update, delete: if false;
    }
  }
}
