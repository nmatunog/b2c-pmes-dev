{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3040",
    "start": "next start -p 3040",
    "lint": "eslint . --max-warnings 0",
    "preflight:api": "bash scripts/preflight-prod-api.sh",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:deploy:safe": "npm run preflight:api && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:deploy:web": "npm run cf:build && wrangler deploy --config wrangler.b2c-pmes-web.jsonc",
    "cf:deploy:web:safe": "npm run preflight:api && npm run cf:build && wrangler deploy --config wrangler.b2c-pmes-web.jsonc",
    "pages:deploy:safe": "npm run preflight:api && vite build && wrangler pages deploy --cwd cloudflare-pages-ui --project-name b2c-pmes-web-ui",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:safe": "npm run cf:deploy:safe",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@jobuntux/psgc": "^0.2.1",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^3.0.3",
    "firebase": "^12.11.0",
    "jose": "^5.9.6",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  }
}
